                  "type" : "integer"
                },
                "result" : {
                  "type" : "string"
                },
                "returnJobID" : {
                  "type" : "string"
                },
                "returnTrackingNumber" : {
                  "type" : "string"
                },
                "returnFoxJob" : {
                  "type" : "string"
                },
                "returnResult" : {
                  "type" : "string"
                }
                
              }
            }
          },
          "405": {
            "description": "Invalid input"
          }
        }
      }
    },
