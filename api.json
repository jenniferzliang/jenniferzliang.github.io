          "application/json",
          "application/xml"
        ],
        "produces": [
          "application/xml",
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Send message with tracking number and order status",
            "required": true,
            "schema": {
              "properties": {
                "phonenumber": {
                  "type": "string",
                  "description": "Phone Number"
                },
                "trackingNumber": {
                  "type": "string",
                  "description": "Tracking Number"
                },
                "url": {
                  "type": "string",
                  "description": "Tracking URL"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "405": {
            "description": "Invalid input"
          }
        }
      }
    },
