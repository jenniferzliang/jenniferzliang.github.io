    "/getQuote" :{
      "post" : {
        "security": [
          {
            "apiKey": []
          }
        ],
        "tags": [
          "Create Order"
        ],
        "summary" : "Get quote for delivery",
        "description" : "Get quote for delivery. Check to see if address is valid and returns the rate choices for the delivery.",
        "operationId" : "getQuote",
        "requestBody" :{
          "content" : {
            "application/json" : {
              "schema" : {
                "type":"object",
                "properties" : {
                  "pieces" : {
                    "type" : "integer",
                    "example" : 1,
                    "description" : "Number of pieces in shipment. Can affect rate and available service types"
                  },
                  "weight" : {
                    "type" : "integer",
                    "example" : 1,
                    "description" : "Total weight of the shipment. Can affect rate and available service types"
                  },
                  "declared_value" : {
                    "type" : "integer",
                    "example" : null,
                    "description" : "Insurable amount.  will affect final rate if non-zero."
                  },
                  "pickup_datetime" : {
                    "type" : "string",
                    "format" : "date-time",
                    "example" : null,
                    "description" : "The date and time in UTC values when the trip will be ready for pickup.  Leaving null will default to ready immediately."
                  },
                  "reference" : {
                    "type" : "string",
                    "example" : null,
                    "description" : "Customer reference for trip. Appears on invoice."
                  },
                  "special_instructions" : {
                    "type" : "string",
                    "example" : null,
                    "description" : "Any specific instructions for this trip.  Will be visible to dispatch and driver."
                  },
                  "delivery_url" : {
                    "type" : "string",
                    "example" : null,
                    "description" : "Any web link that needs to be present on the trip, similar to a customer reference. Visible to driver."
                  },
                  "delivery_sig_required" : {
                    "type" : "integer",
                    "example" : 1,
                    "description" : "Defaults to 1.  setting to 0 will allow delivery without a signature.  (signature is always attempted)"
                  },
                  "description" : {
                    "type": "string",
                    "description" : "description of the trip.  suitable examples would be 'Envelope, Box, Roll, Skid, etc'",
                    "description": "Type of package",
                    "enum": [
                      "Envelope",
                      "Package",
                      "Box",
                      "Skid",
                      "Roll",
                      "Binder",
                      "Book",
                      "Drycleaning",
                      "Flowers",
                      "Bag",
                      "Other"
                    ]
                  },
                  "account_email" : {
                    "type" : "string",
                    "format" : "email",
                    "example" : "jillsmith@example.com",
                    "description" : "will send shipment notifications to this email address including exception and delivery notifications"
                  },
                  "client_email" : {
                    "type" : "string",
                    "format" : "email",
                    "example" : "johnsmith@example.com",
                    "description" : "will send a notification to this email of a shipment bound to them as the receiver with a tracking link."
                  },
                  "address" : {
                    "type" : "object",
                    "properties" : {
                      "name" : {
                        "type" : "string",
                        "example" : "DirectIT Group",
                        "description" : "The company or individual name of the receiver."
                      },
                      "suite" : {
                        "type" : "string",
                        "example" : "Unit 1",
                        "description" : "The suite portion of the address."
                      },
                      "address" : {
                        "type" : "string",
                        "example" : "100 Barclay Parade",
                        "description" : "The road portion of the address."
                      },
                      "city" : {
                        "type" : "string",
                        "example" : "Calgary",
                        "description" : "The city for delivery. If left blank, will default to account default setting as specified when api key setup."
                      },
                      "province" : {
                        "type" : "string",
                        "example" : "Alberta",
                        "description" : "The province.  if left blank, will default to account default setting as specified when api key setup."
                      },
                      "country" : {
                        "type" : "string",
                        "example" : "Canada",
                        "description" : "The country.  if left blank, will default to account default setting as specified when api key setup."
                      },
                      "postal" : {
                        "type" : "string",
                        "example" : "T2P3E7",
                        "description" : "the postal code for the address. Not required."
                      },
                      "latitude" : {
                        "type" : "number",
                        "example" : 0.0,
                        "description" : "Latitude. If known, you may provide the GPS coordinates of the delivery address using these fields.  not required."
                      },
                      "longitude" : {
                        "type" : "number",
                        "example" : 0.0,
                        "description" : "Longitude.  if known, you may provide the GPS coordinates of the delivery address using these fields.  not required."
                      },
                      "contactName" : {
                        "type" : "string",
                        "example" : "John Smith",
                        "description" : "An Attention to name at the delivery. "
                      },
                      "contactPhone" : {
                        "type" : "string",
                        "example" : "123-456-7890",
                        "description" : "A phone number to contact @ the delivery. "
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type" : "array",
                  "items" : {
                    "type":"object",
                    "properties": {
                      "quoteID" : {
                        "type" :"string",
                        "example" : "E8B7B1EC-55B0-4B57-B7F9-E5DC0DE71A97",
                        "description" : "Quote ID of the order request. Valid for 60 seconds to call execute_quote"
                      },
                      "descr" :{
                        "type" : "string",
                        "example" : "Air Service Overnight VPU  Today after 12:57 [ $34.38]",
                        "description" : "Description of rate and delivery method"

                      },
                      "dtCallIn" :{
                        "type" : "string",
                        "format" :"date-time",
                        "description" : "Delivery call in"

                      },
                      "dtDCT" :{
                        "type" : "string",
                        "format" :"date-time",
                        "description" : "delivery date call time"
                      },
                      "rate" :{
                        "type" : "string",
                        "description" : "Rate of package"
                      },
                      "ser_area" :{
                        "type" : "string",
                        "example" : "A",
                        "description" : "Service area"
                      },
                      "ser_time" :{
                        "type" : "integer",
                        "example" : 121,
                        "description" : "Service time"
                      },
                      "distance" : {
                        "type" : "number",
                        "example" : 316234,
                        "description" : "Delivery distance"
                      }
                    }
                  }
                }
              }
            }
          }
          
        }
      }
    },
    "/executeQuote" : {
      "post": {
        "security": [
          {
            "apiKey": []
          }
        ],
        "tags": [
          "Create Order"
        ],
        "summary": "Execute quote",
        "description": "Execute quote and place order using the quote ID retrieved from getQuote",
        "operationId": "executeQuote",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type" : "object",
                "properties" : {
                  "quoteID" : {
                    "type" : "string",
                    "example" : "E8B7B1EC-55B0-4B57-B7F9-E5DC0DE71A97",
                    "description" : "A quoteID obtained from the output of a call to /getQuote."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type" : "array",
                  "items" : {
                    "type":"object",
                    "properties": {
                      "jobID" : {
                        "type" : "string",
                        "example" : "12345",
                        "description" : "jobID"
                      },
                      "rate" : {
                        "type" : "number",
                        "example" : 3.00,
                        "description" : "Rate of delivery"
                      },
                      "ser_area" : {
                        "type" : "string",
                        "example" : "C",
                        "description" : "Service area"
                      },
                      "ser_time" : {
                        "type" : "integer",
                        "example" : 120,
                        "description" : "Service time"
                      },
                      "dtCallIn" : {
                        "type" : "string",
                        "format" : "date-time",
                        "description" : "dctCallIn"
                      },
                      "dtDCT" : {
                        "type" : "string",
                        "format" : "date-time",
                        "description" : "dtDCT"
                      },
                      "TrackNumber" : {
                        "type" : "string",
                        "example" : "TR8323512161586",
                        "description" : "Tracking number"
                      },
                      "TrackNumber" : {
                        "type" : "string",
                        "example" : "https://ship.directx.ca/redirect.php?TrackNumber=TR8323512161586",
                        "description" : "Tracking link to view order"
                      }

                    }
                  }
                }
              }
            }
          }
        }

      }
    },
